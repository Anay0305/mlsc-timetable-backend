# Copy this file to .env and fill in the values.
# All settings are optional unless marked Required.

# ── MongoDB ─────────────────────────────────────────────────────────────
# Connection URI and database name for the timetable store.
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=mlsc_timetable

# ── Admin auth ─────────────────────────────────────────────────────────
# Two ways to authenticate /admin/* requests; either grants access.
#
# 1) Shared bearer token (for CLI/curl/CI). Leave unset to disable this
#    path entirely.
# ADMIN_TOKEN=change-me
#
# 2) Clerk JWT (for the browser admin panel). The frontend sends the
#    Clerk session token; the backend verifies it against Clerk's JWKS
#    and matches the verified `email` claim against the allowlist below.
#
#    Required: your Clerk frontend issuer (find it in the Clerk dashboard
#    under "API Keys" → "Show JWT public key" → the JWT's `iss` claim).
# CLERK_ISSUER=https://your-app.clerk.accounts.dev
#    Optional override; defaults to ${CLERK_ISSUER}/.well-known/jwks.json
# CLERK_JWKS_URL=
#
#    The Clerk session JWT must include an `email` claim. In the Clerk
#    dashboard create a JWT template called `mlsc-admin` with body:
#      { "email": "{{user.primary_email_address}}" }
#    The frontend calls session.getToken({ template: "mlsc-admin" }).
#
# Comma-separated allowlist of admin email addresses (matched
# case-insensitively against the verified Clerk JWT email claim).
# Bootstrap the panel by listing your own email here; add more from the UI
# (POST /admin/users) once you can sign in as admin.
# ADMIN_EMAILS=admin@example.com,you@thapar.edu

# ── HTTP / CORS ────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the browser app. Set this in
# Cloud Run to the exact production frontend origin as well as localhost if
# local development is still needed, for example:
# CORS_ORIGINS=http://localhost:5173,https://your-frontend.example.com
CORS_ORIGINS=http://localhost:5173

# ── Google Cloud Run ───────────────────────────────────────────────────
# Cloud Run injects PORT at runtime. Configure secrets such as MONGODB_URL,
# ADMIN_TOKEN, Clerk settings, and Google credentials in Secret Manager or
# Cloud Run environment variables, not in this file.

# ── Contributors (GET /contributors) ───────────────────────────────────
# Optional GitHub fine-grained token to avoid the 60 req/hr unauthenticated
# rate limit when enriching contributor avatars. Read-only public-repo scope
# is enough.
# GITHUB_TOKEN=your_token_here

# How long (seconds) each contributor's avatar payload is cached in-process
# before it gets re-fetched from GitHub. Default 3600 (1 hour).
# CONTRIBUTORS_CACHE_TTL=3600

# ── Ingest tuning ──────────────────────────────────────────────────────
# Minimum hours between two successful ingest runs (prevents rapid
# re-uploads in quick succession). Default 24.
# INGEST_COOLDOWN_HOURS=24

# How long (hours) an in-progress ingest "snapshot" is kept before it is
# considered stale and a new run is allowed. Default 24.
# INGEST_SNAPSHOT_TTL_HOURS=24

# ── Google Calendar integration ─────────────────────────────────────────
# OAuth 2.0 credentials from the Google Cloud Console
# (APIs & Services → Credentials → OAuth 2.0 Client IDs).
# Leave all three unset to disable the calendar feature entirely.
#
# Required: your OAuth client ID and secret.
# GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-your-secret
#
# The redirect URI registered in Google Cloud Console. Must match exactly.
# For local dev: http://localhost:8000/api/calendar/oauth/callback
# GOOGLE_OAUTH_REDIRECT_URI=https://your-domain.com/api/calendar/oauth/callback
#
# Fernet symmetric key used to encrypt stored OAuth tokens at rest.
# Generate one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required if GOOGLE_OAUTH_CLIENT_ID is set.
# CALENDAR_TOKEN_KEY=your-fernet-key-here
#
# (Deprecated) Global fallback term-end date (yyyy-mm-dd). Prefer setting
# term end dates per-semester from the admin panel instead.
# CALENDAR_TERM_END_DATE=2026-04-30

# ── Persistence / audit ────────────────────────────────────────────────
# Set to 1 to also write JSON snapshots into DATA_DIR for git-tracking.
# JSON_MIRROR=0

# Where the JSON mirror lives (only relevant when JSON_MIRROR=1).
# DATA_DIR=./data

# Auto-commit JSON mirror changes (only relevant when JSON_MIRROR=1).
# GIT_AUTO_COMMIT=0
